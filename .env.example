PORT=3000
NODE_ENV=development

# JWT
JWT_SUMMONS_SECRET=troque-por-um-segredo-longo
JWT_SUMMONS_EXPIRES_IN=72h

# Auth
JWT_SESSION_SECRET=troque-por-um-segredo-de-sessao
JWT_SESSION_EXPIRES_IN=12h
OTP_EXPIRES_MINUTES=10

# Desenvolvimento
AUTH_DEV_MODE=false
AUTH_DEV_SEND_REAL_OTP=false
AUTH_DEV_ADMIN_CPF=40280221851

# WhatsApp
# provider: generic | meta-cloud
WHATSAPP_PROVIDER=generic

# Generic provider
WHATSAPP_API_URL=https://api.seu-provedor.com/messages
WHATSAPP_API_TOKEN=troque-por-token-do-provedor

# Meta Cloud API
WHATSAPP_API_VERSION=v22.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_LANGUAGE_CODE=pt_BR

# Templates
WHATSAPP_TEMPLATE_NAME=intimacao_padrao
WHATSAPP_OTP_TEMPLATE_NAME=otp_login
WHATSAPP_VICTIM_NOTIFICATION_TEMPLATE_NAME=notificacao_vitima
WHATSAPP_PUBLIC_BASE_URL=

# Banco
DB_HOST=localhost
DB_PORT=5432
DB_NAME=delegacia_mulher
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

# Opcional: usar connection string em vez dos campos DB_* acima
# DATABASE_URL=postgresql://usuario:senha@host:5432/delegacia_mulher

SMS_API_URL=https://api.sms-provedor.com/send
SMS_API_TOKEN=troque-por-token-sms
